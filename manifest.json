{
  "manifest_version": 3,
  "name": "Focus Matrix Pro (PW & YT)",
  "version": "4.0",
  "description": "High-performance smart content filter, anti-cheat tracking mechanics, and daily study metrics.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.youtube.com/*",
        "https://*.pw.live/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}